[node name="RichTextLabel" type="RichTextLabel" parent="HBoxContainer/AnomaliesMenuContainer/InfoContainer173/HBoxContainer" unique_id=774508990]
layout_mode = 2
size_flags_horizontal = 3
text = "SCP-173 is a tall statue made of concrete that can move when not in direct eyesight of anyone. 

Capturing SCP-173 requires maintaining distance and constant eye contact. Members of the capture team should only close their eyes for short periods of time to get it closer to the capture area and alternate who is blinking at a given moment."

