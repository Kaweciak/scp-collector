[node name="RichTextLabel" type="RichTextLabel" parent="HBoxContainer/AnomaliesMenuContainer/InfoContainer428/HBoxContainer" unique_id=1656124781]
layout_mode = 2
size_flags_horizontal = 3
text = "I am a toaster. My name is SCP-482. I cause hallucinations to whoever is looking at me for prolonged periods of time, especially when I'm being held. Whoever is exposed to me for prolonged periods of time starts thinking of themselves as me.

To capture me scientists need to cooperate. They need to ensure one isn't directly looking me for too long by closing their eyes and giving each other directions or changing the person that holds me."

