[node name="RichTextLabel" type="RichTextLabel" parent="HBoxContainer/AnomaliesMenuContainer/InfoContainer184/HBoxContainer" unique_id=827721566]
layout_mode = 2
size_flags_horizontal = 3
text = "SCP-184 is a small, metal dodecahedron. It causes any space it's located in to constantly grow in size from the inside, regardless of the size of its shell. Any structure holding SCP-184 will have additional rooms that seem to be violating the laws of physics.

Capturing SCP-184 requires good navigational skills and a large capture squad. Navigating the modified structures can be more time consuming than it seems as their true size cannot be accurately estimated."

